# LLM：二选一或同时配置（优先 OPENAI，否则 KIMI）
OPENAI_API_KEY=
KIMI_CODE_API_KEY=
# KimiCode 专用（KIMI_CODE_API_KEY 来自 https://www.kimi.com/code/console，与 OpenClaw 的 kimi-coding/k2p5 同源）
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_MODEL=k2p5
# KIMI_USER_AGENT=KimiCLI/1.3   # 可选，Kimi Code 按 UA 白名单放行，默认已设
# 若用通用 Kimi（Moonshot）：KIMI_BASE_URL=https://api.moonshot.cn/v1  KIMI_MODEL=moonshot-v1-8k

APP_ENV=dev
DEFAULT_SYMBOL=NVDA

# Paper 风控（授权就绪后可配，见 docs/deferred_authorization.md）
# PAPER_MAX_POSITION_PCT=20
# PAPER_DAILY_STOP_LOSS_PCT=2
# Kill Switch：STOP_PAPER=1 或项目根 .paper_stop 文件存在时 run_paper 不执行
# STOP_PAPER=0

# 实盘前 L3/L4：回测阈值（run_backtest 校验）
# MIN_TRADE_COUNT=1
# MAX_DRAWDOWN_PCT=20

# 实盘前 L2：OOS 评估窗口天数（run_backtest_windows --oos-days 或脚本内默认）
# OOS_DAYS=30

# IBKR Paper（TWS/IB Gateway 已启动且 API 已开启时填写；端口 Gateway 多为 4002，TWS 多为 7497）
# 配置后 run_paper 走 IBKR 下单（L5）；验证连通性：python scripts/verify_ibkr.py
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4002
# 账户/下单用 client id（默认 1）；行情用 IBKR_MARKET_DATA_CLIENT_ID（默认 2），避免同一 id 频繁重连导致 Error 1100
# IBKR_CLIENT_ID=1
# IBKR_MARKET_DATA_CLIENT_ID=2
# 连接超时（秒）
# IBKR_CONNECT_TIMEOUT=60
# positions 请求单独超时（秒）；日志 "positions request timed out (source: positions step)" 时可调大
# IBKR_POSITIONS_TIMEOUT=45
# connect 后等待秒数再发首包；0=不等待（更快，若出现 timeout 可改为 1 或 2）
# IBKR_WARMUP_DELAY=2
# 断开后等待秒数再返回，便于 Gateway 释放 client id
# IBKR_DISCONNECT_DELAY=1
# PAPER_INITIAL_CASH=100000
